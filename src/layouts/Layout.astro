---
import '../styles/global.css';
import type { Locale, Translation } from '../i18n/translations';

interface Props {
  lang: Locale;
  t: Translation;
}

const { lang, t } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og-image.png', Astro.site).href;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="canonical" href={canonicalURL} />

  <title>{t.meta.title}</title>
  <meta name="description" content={t.meta.description} />

  <!-- Theme -->
  <meta name="theme-color" content="#0A0E14" />
  <meta name="color-scheme" content="dark" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={t.meta.title} />
  <meta property="og:description" content={t.meta.description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content={lang === 'fr' ? 'fr_FR' : 'en_US'} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={t.meta.title} />
  <meta name="twitter:description" content={t.meta.description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Alternate languages -->
  <link rel="alternate" hreflang="fr" href={new URL('/', Astro.site).href} />
  <link rel="alternate" hreflang="en" href={new URL('/en/', Astro.site).href} />
  <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site).href} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />

  <!-- JSON-LD Person -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Tahirihasina Rakotomanga",
    "jobTitle": lang === 'fr' ? "Ingénieur Système & Sécurité · DevOps" : "Systems & Security Engineer · DevOps",
    "email": "tahirihasinarakotomanga@gmail.com",
    "url": canonicalURL.href,
    "sameAs": [
      "https://www.linkedin.com/in/tahirihasina-rakotomanga"
    ],
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Antananarivo",
      "addressCountry": "MG"
    },
    "knowsAbout": ["DevOps", "Cybersecurity", "CI/CD", "Docker", "Kubernetes", "Ansible", "AWS", "Linux", "Pentesting", "SIEM", "Wazuh"],
    "alumniOf": {
      "@type": "EducationalOrganization",
      "name": "Université d'Antananarivo — MISA"
    }
  })}></script>
</head>
<body>
  <slot />
  <script>
    document.querySelectorAll('a[href^="#"]').forEach((a) => {
      a.addEventListener('click', (e) => {
        const id = (a as HTMLAnchorElement).getAttribute('href') || '';
        if (id.length > 1) {
          const el = document.querySelector(id);
          if (el) {
            e.preventDefault();
            el.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });
    });
  </script>
</body>
</html>
