---
import Terminal from './Terminal.astro';
import type { Translation } from '../i18n/translations';

interface Props {
  t: Translation;
}

const { t } = Astro.props;
---
<section class="hero" id="hero">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-enter">
        <div class="badge">{t.hero.badge}</div>
        <h1>
          {t.hero.titleLine1Before}<span class="accent">{t.hero.titleLine1Accent}</span><br />
          {t.hero.titleLine2Connector}<span class="mono">{t.hero.titleLine2Mono}</span>
        </h1>
        <p class="hero-tagline">{t.hero.tagline}</p>
        <div class="hero-meta">
          <span>{t.hero.location}</span>
          <span>{t.hero.remote}</span>
          <span>{t.hero.education}</span>
        </div>
        <div class="hero-cta">
          <a href="#contact" class="btn btn-primary">{t.hero.ctaPrimary}</a>
          <a href="#projects" class="btn btn-ghost">{t.hero.ctaSecondary}</a>
        </div>
      </div>
      <div class="hero-enter-terminal">
        <Terminal t={t} />
      </div>
    </div>
  </div>
</section>
