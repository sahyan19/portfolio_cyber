---
import Layout from '../layouts/Layout.astro';
import { translations } from '../i18n/translations';

const lang = 'fr';
const t = translations.fr;
---
<Layout lang={lang} t={t}>
  <main class="container" style="min-height: 70vh; display: grid; place-items: center; text-align: center; padding-top: 96px;">
    <div>
      <span class="section-eyebrow">sent</span>
      <h1 class="section-title" style="margin-top: 12px;">Message envoyé ✓</h1>
      <p class="section-lead" style="margin: 16px auto 32px;">Merci, je reviens vers toi sous 48h.</p>
      <a href="/" class="btn btn-primary">← Retour à l'accueil</a>
    </div>
  </main>
</Layout>
